{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "lib": [
            "es6",
            "dom"
        ],
        "module": "es6",
        "moduleResolution": "node",
        "noImplicitAny": true,
        "outDir": "build/esm/src",
        "sourceMap": true,
        "target": "es6",
        "typeRoots": [
            "./node_modules/@types",
            "./types",
            "./types/@mapbox"
        ],
        "types": [
            "earcut",
            "falcor",
            "falcor-http-datasource",
            "jasmine",
            "latlon-geohash",
            "node",
            "pbf",
            "polylabel",
            "rbush",
            "s2-geometry",
            "three",
            "unitbezier",
            "virtual-dom"
        ]
    },
    "files": [
        "./src/Mapillary.ts"
    ]
